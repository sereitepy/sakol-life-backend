# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres.your-project-ref
DATABASE_PASSWORD=your-database-password

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project ref is the subdomain of your Supabase URL
# e.g. https://yjlxczffhgicwyjftrn.supabase.co → ref is: yjlxczffhgicwyjftrn
# NOTE: We no longer use the JWT secret. ES256 validation uses the public JWKS endpoint.
SUPABASE_PROJECT_REF=your-project-ref-here

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
